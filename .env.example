# Kleerr CST (staging CDN — good default for Vercel preview)
PUBLIC_KLEERR_CST_ORIGIN=https://scripts-stg.kleerr.com
PUBLIC_KLEERR_CST_CORE=kleerr.core.staging.js
PUBLIC_KLEERR_CLIENT_ID=45723407-fb03-48f2-95f9-36577489cccc

# Local CST through ngrok (forward your CST host; when the tunnel restarts, update this host):
# Option A — origin only (cid + v=latest added automatically):
# PUBLIC_KLEERR_CST_ORIGIN=https://onionlike-jacklyn-scrawly.ngrok-free.dev
#
# Option B — full script URL (overrides origin/core/cid query construction):
# PUBLIC_KLEERR_CST_SCRIPT_URL=https://onionlike-jacklyn-scrawly.ngrok-free.dev/kleerr.core.staging.js?cid=45723407-fb03-48f2-95f9-36577489cccc&v=latest

# Production example:
# PUBLIC_KLEERR_CST_ORIGIN=https://scripts.kleerr.com
# PUBLIC_KLEERR_CST_CORE=kleerr.core.js
